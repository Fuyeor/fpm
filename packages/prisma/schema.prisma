// packages/prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
  schemas    = ["public"]
}

/// Synced from Main IdP
model user {
  id                  String                @id @db.Uuid
  username            String                @unique @db.Citext
  nickname            String                @db.VarChar(64)
  avatar              String?               @db.VarChar(255)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)

  token               token[]
  organization_member organization_member[]
  user_refresh_token  user_refresh_token[]

  @@schema("public")
}

/// Web session rotation tokens (JWTs)
model user_refresh_token {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique @db.VarChar(512)
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user_agent String?
  ip_address String?  @db.VarChar(45)
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@schema("public")
}

/// Represents the @scope Namespace, e.g., '@fuyeor'
model organization {
  id                  String                @id @db.Uuid
  name                String                @unique @db.Citext
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  organization_member organization_member[]
  packages            packages[]

  @@schema("public")
}

/// Many-to-Many join table with roles for Scope membership
model organization_member {
  organization_id String       @db.Uuid
  user_id         String       @db.Uuid
  role            String       @db.VarChar(32)
  organization    organization @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user            user         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([organization_id, user_id])
  @@schema("public")
}

/// Package metadata, represented as @scope/name
/// the original name 'package' is prisma reserved
model packages {
  id              String            @id @db.Uuid
  organization_id String            @db.Uuid
  name            String            @db.VarChar(255)
  full_name       String            @unique @db.Citext
  description     String?
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  organization    organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  package_version package_version[]

  @@map("package")
  @@schema("public")
}

/// Specific version details for published packages
model package_version {
  id             String         @id @db.Uuid
  package_id     String         @db.Uuid
  version        String         @db.VarChar(64)
  manifest       Json
  dist_tarball   String         @db.VarChar(255)
  dist_shasum    String         @db.VarChar(128)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  packages packages @relation(fields: [package_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([package_id, version])
  @@schema("public")
}

/// CLI Personal Access Tokens, e.g., 'fpm_xxx'
model token {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  name       String   @db.VarChar(64)
  token_hash String   @unique @db.VarChar(64)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}
