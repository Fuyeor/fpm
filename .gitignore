# ========================
# 环境变量 (敏感文件!)
# ========================
.env
.env.production
.env.development
appsettings.Development.json

# ========================
# 依赖管理
# ========================

# 忽略所有子目录的锁文件（npm/pnpm/cargo）
**/pnpm-lock.yaml
**/package-lock.json
**/Cargo.lock

# 只保留根目录的锁文件
!pnpm-lock.yaml
!Cargo.lock

# 忽略私有包
packages/vendor/fuyeor/packages

# ========================
# 构建输出
# ========================

# cargo 与 npm 依赖
**/target
**/node_modules

# .NET 编译产生的二进制文件夹
bin/
obj/

# 构建文件
**/dist
**/build
**/generated

# 后端数据目录
**/back-end/public
**/back-end/storage
# 生成的前端语言文件
**/front-end/public/assets/locale
# Prisma 生成文件
**/packages/prisma/*/client

# ========================
# 临时文件和缓存
# ========================

.tmp
.temp
.turbo

# 临时文件目录
**/temp
# python 缓存目录
**/__pycache__
# 前端 service worker 开发目录
**/dev-dist

# ========================
# 测试相关
# ========================

**/coverage

# ========================
# 日志文件
# ========================

logs
*.log
npm-debug.log*
pnpm-debug.log*

# ========================
# IDE 配置
# ========================

.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ========================
# 系统文件
# ========================

.DS_Store
Thumbs.db